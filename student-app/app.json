{
  "expo": {
    "name": "博学",
    "slug": "union-student-app",
    "version": "1.0.0.63",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "union-app",
    "updates": {
      "url": "https://u.expo.dev/30915e7c-2905-4e7b-81b1-277f9d93128c"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#B8362C"
    },
    "plugins": [
      "expo-router",
      [
        "expo-quick-actions",
        {
          "androidIcons": {
            "shortcut_dictionary": "./assets/shortcuts/shortcut_dictionary.png",
            "shortcut_bus": "./assets/shortcuts/shortcut_bus.png",
            "shortcut_handbook": "./assets/shortcuts/shortcut_handbook.png",
            "shortcut_train": "./assets/shortcuts/shortcut_train.png",
            "shortcut_classroom": "./assets/shortcuts/shortcut_classroom.png",
            "shortcut_studyroom": "./assets/shortcuts/shortcut_studyroom.png",
            "shortcut_articles": "./assets/shortcuts/shortcut_articles.png",
            "shortcut_announcements": "./assets/shortcuts/shortcut_announcements.png",
            "shortcut_settings": "./assets/shortcuts/shortcut_settings.png"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#A31621",
          "sounds": []
        }
      ],
      "expo-sqlite",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#B8362C"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studentunion.app",
      "infoPlist": {
        "NSCameraUsageDescription": "允许访问相机以上传头像",
        "NSPhotoLibraryUsageDescription": "允许访问相册以上传头像",
        "NSLocationWhenInUseUsageDescription": "我们需要您的位置以在公交地图上显示您的当前位置并查找附近站点。",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "trenitalia",
          "italo",
          "italotreno"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#B8362C",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.studentunion.app",
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30915e7c-2905-4e7b-81b1-277f9d93128c"
      }
    },
    "owner": "smxlrs"
  }
}
